# Auth.js
AUTH_SECRET=your_auth_secret
AUTH_KAKAO_ID=your_kakao_rest_api_key
AUTH_KAKAO_SECRET=your_kakao_client_secret
ADMIN_KAKAO_IDS=your_kakao_id:이름
# Auth.js — 같은 네트워크 내 실기기 테스트 시 개발 머신의 IP로 변경 (예: http://192.168.0.10:3000)
AUTH_URL=http://your_local_ip

# Supabase (서버 전용)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
STORAGE_BUCKET=images

# Discord Webhook (에러 로깅용)
DISCORD_ERROR_WEBHOOK_URL=your_discord_error_webhook_url
DISCORD_WARN_WEBHOOK_URL=your_discord_warn_webhook_url

